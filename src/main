#![no_std]
#![no_main]

mod buttons;
mod buzzer;
mod display;
mod game;
mod leds;
mod songs;
mod servo;

use cortex_m_rt::entry;
use panic_halt as _;

use game::{Difficulty, Game, GameMode, GameState};
use songs::{GRAVITY_FALLS, DOOM, TOKYO_DRIFT};
use stm32u5::stm32u545::Peripherals;

#[entry]
fn main() -> ! {
    let dp = Peripherals::take().unwrap();

    leds::init_leds(&dp);
    buttons::init_buttons(&dp);
    buzzer::init_buzzer(&dp);
    display::init_display(&dp);

    servo::init_servos(&dp);

    let mut game = Game::new();

    let mut idle_step: u8 = 0;
    let mut menu_index: u8 = 0;
    let mut level_index: u8 = 0;
    display::show_boot(&dp);

    servo::boot_animation(&dp);

    display::show_main_menu(&dp, menu_index);

    game.state = GameState::MainMenu;

    loop {

        match game.state {

            GameState::Boot => {

                game.state = GameState::MainMenu;

                display::show_main_menu(&dp, menu_index);
            }

            GameState::MainMenu => {

                if buttons::button_pressed(&dp, 3) {

                    buzzer::play_note(&dp, 1000, 15);

                    if menu_index == 0 {
                        menu_index = 2;
                    } else {
                        menu_index -= 1;
                    }

                    display::show_main_menu(&dp, menu_index);

                    cortex_m::asm::delay(250_000);

                } else if buttons::button_pressed(&dp, 1) {

                    buzzer::play_note(&dp, 1000, 15);

                    menu_index = (menu_index + 1) % 3;

                    display::show_main_menu(&dp, menu_index);

                    cortex_m::asm::delay(250_000);

                } else if buttons::button_pressed(&dp, 4) {

                    buzzer::play_note(&dp, 1000, 15);

                    level_index = 0;

                    if menu_index == 0 {

                        game.set_mode(GameMode::Rhythm);

                        display::show_rhythm_level_menu(&dp, level_index);

                        game.state = GameState::DifficultyMenu;

                    } else if menu_index == 1 {

                        game.set_mode(GameMode::Memory);

                        display::show_memory_level_menu(&dp, level_index);

                        game.state = GameState::DifficultyMenu;

                    } else {

                        display::show_leaderboard_menu(&dp, level_index);

                        game.state = GameState::LeaderboardMenu;
                    }

                    cortex_m::asm::delay(250_000);

                } else {

                    leds::idle_animation_step(&dp, idle_step);

                    idle_step = (idle_step + 1) % 5;
                }
            }

            GameState::DifficultyMenu => {

                if buttons::button_pressed(&dp, 3) {

                    buzzer::play_note(&dp, 1000, 15);

                    if level_index == 0 {
                        level_index = 3;
                    } else {
                        level_index -= 1;
                    }

                    if game.mode == GameMode::Rhythm {

                        display::show_rhythm_level_menu(&dp, level_index);

                    } else {

                        display::show_memory_level_menu(&dp, level_index);
                    }

                    cortex_m::asm::delay(250_000);

                } else if buttons::button_pressed(&dp, 1) {

                    buzzer::play_note(&dp, 1000, 15);

                    level_index = (level_index + 1) % 4;

                    if game.mode == GameMode::Rhythm {

                        display::show_rhythm_level_menu(&dp, level_index);

                    } else {

                        display::show_memory_level_menu(&dp, level_index);
                    }

                    cortex_m::asm::delay(250_000);

                } else if buttons::button_pressed(&dp, 4) {

                    buzzer::play_note(&dp, 1000, 15);

                    if level_index == 3 {

                        menu_index = 0;
                        level_index = 0;

                        display::show_main_menu(&dp, menu_index);

                        game.state = GameState::MainMenu;

                        cortex_m::asm::delay(250_000);

                    } else {

                        match level_index {

                            0 => game.set_difficulty(Difficulty::Easy),
                            1 => game.set_difficulty(Difficulty::Medium),
                            _ => game.set_difficulty(Difficulty::Hard),
                        }

                        leds::all_off(&dp);

                        display::show_wait_start(&dp);

                        game.state = GameState::WaitStart;

                        cortex_m::asm::delay(250_000);
                    }
                }
            }

            GameState::LeaderboardMenu => {

                if buttons::button_pressed(&dp, 3) {

                    buzzer::play_note(&dp, 1000, 15);

                    if level_index == 0 {
                        level_index = 2;
                    } else {
                        level_index -= 1;
                    }

                    display::show_leaderboard_menu(&dp, level_index);

                    cortex_m::asm::delay(250_000);

                } else if buttons::button_pressed(&dp, 1) {

                    buzzer::play_note(&dp, 1000, 15);

                    level_index = (level_index + 1) % 3;

                    display::show_leaderboard_menu(&dp, level_index);

                    cortex_m::asm::delay(250_000);

                } else if buttons::button_pressed(&dp, 4) {

                    buzzer::play_note(&dp, 1000, 15);

                    if level_index == 0 {

                        display::show_rhythm_leaderboard(
                            &dp,
                            game.rhythm_highscores[0],
                            game.rhythm_highscores[1],
                            game.rhythm_highscores[2],
                        );

                        game.state = GameState::LeaderboardView;

                    } else if level_index == 1 {

                        display::show_memory_leaderboard(
                            &dp,
                            game.memory_highscores[0],
                            game.memory_highscores[1],
                            game.memory_highscores[2],
                        );

                        game.state = GameState::LeaderboardView;

                    } else {

                        menu_index = 0;
                        level_index = 0;

                        display::show_main_menu(&dp, menu_index);

                        game.state = GameState::MainMenu;
                    }

                    cortex_m::asm::delay(250_000);
                }
            }

            GameState::LeaderboardView => {

                if buttons::button_pressed(&dp, 4) {

                    buzzer::play_note(&dp, 1000, 15);

                    level_index = 0;

                    display::show_leaderboard_menu(&dp, level_index);

                    game.state = GameState::LeaderboardMenu;

                    cortex_m::asm::delay(250_000);
                }
            }

            GameState::WaitStart => {

                if buttons::button_pressed(&dp, 4) {

                    buzzer::play_note(&dp, 1000, 15);

                    game.reset_score();

                    leds::all_off(&dp);

                    game.state = GameState::Countdown;

                } else {

                    leds::wait_start_animation(&dp);
                }
            }

            GameState::Countdown => {

                display::show_ready(&dp);

                for _ in 0..4 {

                    leds::all_on(&dp);

                    buzzer::play_note(&dp, 700, 40);

                    cortex_m::asm::delay(120_000);

                    leds::all_off(&dp);

                    cortex_m::asm::delay(120_000);
                }

                display::clear_screen(&dp);

                display::show_go(&dp);

                buzzer::play_note(&dp, 1000, 220);

                cortex_m::asm::delay(100_000);

                display::clear_screen(&dp);

                game.state = GameState::Gameplay;
            }

            GameState::Gameplay => {

                match game.mode {

                    GameMode::Rhythm => {

                        match game.difficulty {

                            Difficulty::Easy => {

                                display::show_rhythm_playing(
                                    &dp,
                                    "EASY",
                                    "TOKYO DRIFT"
                                );

                                buzzer::play_song(
                                    &dp,
                                    TOKYO_DRIFT,
                                    &mut game.score,
                                    0
                                );
                            }

                            Difficulty::Medium => {

                                display::show_rhythm_playing(
                                    &dp,
                                    "MEDIUM",
                                    "GRAVITY FALLS"
                                );

                                buzzer::play_song(
                                    &dp,
                                    GRAVITY_FALLS,
                                    &mut game.score,
                                    1
                                );
                            }

                            Difficulty::Hard => {

                                display::show_rhythm_playing(
                                    &dp,
                                    "HARD",
                                    "DOOM"
                                );

                                buzzer::play_song(
                                    &dp,
                                    DOOM,
                                    &mut game.score,
                                    2
                                );
                            }
                        }
                    }

                    GameMode::Memory => {

                        match game.difficulty {

                            Difficulty::Easy => {

                                display::show_memory_playing(&dp, "EASY");

                                game::play_memory_game(
                                    &dp,
                                    &mut game.score,
                                    500,
                                    160
                                );
                            }

                            Difficulty::Medium => {

                                display::show_memory_playing(&dp, "MEDIUM");

                                game::play_memory_game(
                                    &dp,
                                    &mut game.score,
                                    380,
                                    100
                                );
                            }

                            Difficulty::Hard => {

                                display::show_memory_playing(&dp, "HARD");

                                game::play_memory_game(
                                    &dp,
                                    &mut game.score,
                                    280,
                                    60
                                );
                            }
                        }
                    }
                }

                leds::all_off(&dp);

                game.state = GameState::Results;
            }

            GameState::Results => {

                let new_highscore = game.update_highscore();

                display::show_score(&dp, game.score);

                if new_highscore {

                    display::show_text_screen(
                        &dp,
                        "NEW HIGH",
                        "SCORE"
                    );

                    servo::highscore_animation(&dp);
                }

                leds::all_off(&dp);

                cortex_m::asm::delay(6_000_000);

                menu_index = 0;
                level_index = 0;

                display::show_main_menu(&dp, menu_index);

                game.state = GameState::MainMenu;
            }
        }
    }
}
