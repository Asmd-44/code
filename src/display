    draw_text(dp, 2, 20, "WELCOME!");
}


pub fn show_rhythm_level_menu(dp: &Peripherals, selected: u8) {

    clear_line(dp, 0);

    draw_text(dp, 0, 20, "RHYTHM LEVEL");

    if selected == 0 {
        draw_menu_line(dp, 2, "> EASY");
        draw_menu_line(dp, 3, "  MEDIUM");
        draw_menu_line(dp, 4, "  HARD");
        draw_menu_line(dp, 5, "  BACK");
    } else if selected == 1 {
        draw_menu_line(dp, 2, "  EASY");
        draw_menu_line(dp, 3, "> MEDIUM");
        draw_menu_line(dp, 4, "  HARD");
        draw_menu_line(dp, 5, "  BACK");
    } else if selected == 2 {
        draw_menu_line(dp, 2, "  EASY");
        draw_menu_line(dp, 3, "  MEDIUM");
        draw_menu_line(dp, 4, "> HARD");
        draw_menu_line(dp, 5, "  BACK");
    } else {
        draw_menu_line(dp, 2, "  EASY");
        draw_menu_line(dp, 3, "  MEDIUM");
        draw_menu_line(dp, 4, "  HARD");
        draw_menu_line(dp, 5, "> BACK");
    }
}

